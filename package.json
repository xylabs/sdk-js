{
  "name": "@xylabs/sdk-js-build",
  "version": "5.0.86",
  "private": true,
  "description": "Base functionality used throughout XY Labs TypeScript/JavaScript libraries",
  "keywords": [
    "xylabs",
    "utility",
    "typescript",
    "esm"
  ],
  "homepage": "https://xylabs.com",
  "bugs": {
    "url": "git+https://github.com/xylabs/sdk-js/issues",
    "email": "support@xylabs.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xylabs/sdk-js.git"
  },
  "license": "LGPL-3.0-only",
  "author": {
    "name": "XY Labs Development Team",
    "email": "support@xylabs.com",
    "url": "https://xylabs.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/neutral/index.d.ts",
      "default": "./dist/neutral/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/neutral/index.mjs",
  "types": "./dist/neutral/index.d.ts",
  "files": [
    "dist",
    "!**/*.bench.*",
    "!**/*.spec.*",
    "!**/*.test.*"
  ],
  "workspaces": [
    "packages/**/*"
  ],
  "scripts": {
    "build-typedoc-site": "xy gen-docs @xylabs/sdk-js",
    "readme:gen": "node scripts/readme-gen.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "~25.4.0",
    "@typescript-eslint/eslint-plugin": "~8.57.0",
    "@typescript-eslint/parser": "~8.57.0",
    "@vitest/browser": "~4.0.18",
    "@vitest/browser-playwright": "~4.0.18",
    "@vitest/coverage-v8": "~4.0.18",
    "@xylabs/eslint-config-flat": "~7.4.17",
    "@xylabs/readme-gen": "^5.0.86",
    "@xylabs/ts-scripts-yarn3": "~7.4.17",
    "@xylabs/tsconfig": "~7.4.17",
    "dotenv": "~17.3.1",
    "eslint": "~10.0.3",
    "eslint-import-resolver-typescript": "~4.4.4",
    "jsdom": "~28.1.0",
    "knip": "~5.86.0",
    "playwright": "~1.58.2",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "~4.0.18"
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=18.17.1"
  },
  "engineStrict": true,
  "volta": {
    "node": "22.3.0",
    "yarn": "1.22.19"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
