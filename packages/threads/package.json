{
  "name": "@xylabs/threads",
  "version": "4.6.0",
  "description": "Web workers & worker threads as simple as a function call",
  "keywords": [
    "thread",
    "worker",
    "pool",
    "spawn",
    "isomorphic",
    "parallel",
    "observable",
    "worker_threads"
  ],
  "homepage": "https://threads.js.org",
  "bugs": {
    "url": "git+https://github.com/andywer/threads.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andywer/threads.js.git"
  },
  "funding": "https://github.com/andywer/threads.js?sponsor=1",
  "license": "MIT",
  "author": "Andy Wermke (https://github.com/andywer)",
  "sideEffects": [
    "./dist*/master/register.js",
    "./dist*/worker/index.js",
    "./register.*js",
    "./worker.*js"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/neutral/index.mjs"
    },
    "./implementation": {
      "types": "./dist/types/implementation.d.ts",
      "import": "./dist/neutral/implementation.mjs"
    },
    "./master": {
      "types": "./dist/types/master/index.d.ts",
      "import": "./dist/neutral/master/index.mjs"
    },
    "./messenger": {
      "types": "./dist/types/messenger.d.ts"
    },
    "./observable": {
      "types": "./dist/types/observable.d.ts",
      "import": "./dist/neutral/observable.mjs"
    },
    "./register": {
      "types": "./dist/types/master/register.d.ts",
      "import": "./dist/neutral/master/register/index.mjs"
    },
    "./worker": {
      "types": "./dist/types/worker/bundle-entry.d.ts",
      "import": "./dist/neutral/worker/bundle-entry.mjs"
    }
  },
  "module": "dist/neutral/index.mjs",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/**",
    "*.js",
    "*.mjs",
    "*.ts"
  ],
  "scripts": {
    "test": "yarn test:library && yarn test:tooling && yarn test:puppeteer:basic && yarn test:puppeteer:webpack",
    "test:library": "cross-env TS_NODE_FILES=true vitest ./test/**/*.test.ts",
    "test:puppeteer:basic": "puppet-run --plugin=mocha --bundle=./test/workers/:workers/ --serve=./bundle/worker.js:/worker.js ./test/*.chromium*.ts",
    "test:puppeteer:webpack": "puppet-run --serve ./test-tooling/webpack/dist/app.web/0.worker.js --serve ./test-tooling/webpack/dist/app.web/1.worker.js --plugin=mocha ./test-tooling/webpack/webpack.chromium.mocha.ts",
    "test:tooling": "cross-env TS_NODE_FILES=true vitest ./test-tooling/**/*.test.ts"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "files": [
      "./test/**/*.test.ts",
      "./test-tooling/**/*.test.ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "serial": true
  },
  "dependencies": {
    "callsites-3-1-0": "npm:callsites@3.1.0",
    "debug": "^4.4.0",
    "is-observable-2-1-0": "npm:is-observable@2.1.0",
    "observable-fns": "^0.6.1"
  },
  "devDependencies": {
    "@babel/types": "^7.26.9",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^22.13.9",
    "@xylabs/eslint-config-flat": "^6.0.8",
    "@xylabs/ts-scripts-yarn3": "^6.0.8",
    "@xylabs/tsconfig": "^6.0.8",
    "cross-env": "^7.0.3",
    "puppet-run": "^0.11.4",
    "raw-loader": "^4.0.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.34.9",
    "threads-plugin": "^1.4.0",
    "tiny-worker": "^2.3.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7",
    "webpack": "^5.98.0"
  },
  "optionalDependencies": {
    "tiny-worker": "^2.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
